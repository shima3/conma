#!/usr/bin/env python3
import sys
import re

class ASTNode:
    def __init__(self, node_type, line, col, value=None):
        self.type = node_type
        self.line = line
        self.col = col
        self.value = value
        self.children = []
        self.is_local = False
        self.index = None # Local: True de Bruijn Index, Global: Sequence No

def tokenize_sexp(text):
    """Tokenize S-expression text into a flat list of tokens.
    Tokens are: '(', ')', or an atom string.
    Strings enclosed in double quotes are kept intact including the quotes.
    """
    tokens = []
    i = 0
    n = len(text)
    while i < n:
        c = text[i]
        if c in ' \t\n\r':
            i += 1
        elif c == '(':
            tokens.append('(')
            i += 1
        elif c == ')':
            tokens.append(')')
            i += 1
        elif c == '"':
            # Quoted string: collect until closing "
            j = i + 1
            while j < n:
                if text[j] == '\\':
                    j += 2
                elif text[j] == '"':
                    j += 1
                    break
                else:
                    j += 1
            tokens.append(text[i:j])
            i = j
        else:
            # Atom: collect until whitespace or paren
            j = i
            while j < n and text[j] not in ' \t\n\r()':
                j += 1
            tokens.append(text[i:j])
            i = j
    return tokens


def parse_sexp_tokens(tokens, pos):
    """Parse one S-expression from tokens starting at pos.
    Returns (ASTNode, next_pos).
    Expects tokens[pos] == '('.
    """
    assert tokens[pos] == '('
    pos += 1  # consume '('

    # First atom: NodeType
    ntype = tokens[pos]
    pos += 1

    # Second element: coordinate tuple (line col ["filename"])
    assert tokens[pos] == '('
    pos += 1  # consume '('
    lnum = tokens[pos]; pos += 1
    col  = tokens[pos]; pos += 1

    # Optional filename (quoted string) for Program node
    filename = None
    if tokens[pos] != ')':
        filename = tokens[pos]; pos += 1
    assert tokens[pos] == ')'; pos += 1  # consume ')'

    # Build node; value will be set for terminal nodes below
    node = ASTNode(ntype, lnum, col)

    # Parse children / value depending on node type
    if ntype == 'Variable':
        # (Variable (l c) name)
        node.value = tokens[pos]; pos += 1
    elif ntype == 'String':
        # (String (l c) "value")
        node.value = tokens[pos]; pos += 1
    elif ntype == 'SInfo':
        # (SInfo (l c) "f" "l" "c" ...)
        parts = []
        while tokens[pos] != ')':
            parts.append(tokens[pos]); pos += 1
        node.value = ' '.join(parts)
    elif ntype == 'Null':
        pass  # no value, no children
    elif ntype == 'Program':
        # filename was captured from coord tuple above
        if filename:
            node.value = filename.strip('"')
        # children
        while tokens[pos] != ')':
            child, pos = parse_sexp_tokens(tokens, pos)
            node.children.append(child)
    else:
        # Non-terminal: parse children until ')'
        while tokens[pos] != ')':
            child, pos = parse_sexp_tokens(tokens, pos)
            node.children.append(child)

    assert tokens[pos] == ')'; pos += 1  # consume closing ')'
    return node, pos


def parse_ast_stream(lines):
    """Parse S-expression AST stream from parser output."""
    text = ''.join(lines)
    tokens = tokenize_sexp(text)
    roots = []
    pos = 0
    while pos < len(tokens):
        if tokens[pos] == '(':
            node, pos = parse_sexp_tokens(tokens, pos)
            roots.append(node)
        else:
            pos += 1
    return roots


class Resolver:
    def __init__(self):
        self.global_registry = {} # name -> {id, value_node}
        self.global_order = []    # name のリスト
        self.global_count = 0     # 0始まり

    def collect_definitions(self, node):
        """第1パス: Global Definition の収集"""
        if node.type == "Definition":
            var_node = next((c for c in node.children if c.type == "Variable"), None)
            if var_node:
                name = var_node.value.strip('"')
                val_node = node.children[1] if len(node.children) > 1 else None
                if name not in self.global_registry:
                    self.global_registry[name] = {"id": None, "value": val_node}
        
        for child in node.children:
            self.collect_definitions(child)

    def resolve(self, node, scope_stack):
        """第2パス: スコープ解決と de Bruijn Index 計算"""
        
        new_scope = None
        # Function または Lambda に対応
        if node.type in ["Function", "Lambda"]:
            head_node = next((c for c in node.children if c.type == "Head"), None)
            if head_node:
                # 右側の引数ほどスタックの上（Index 0に近い）に来るように管理
                new_scope = [v.value.strip('"') for v in head_node.children if v.type == "Variable"]
                scope_stack.append(new_scope)

        if node.type == "Variable":
            name = node.value.strip('"')
            found_local = False
            
            # --- True de Bruijn Index 計算 ---
            # scope_stack = [ [x, y], [z] ]  (左が古いスコープ)
            # z=0, y=1, x=2 となるように計算
            accumulated_binders = 0
            for scope in reversed(scope_stack):
                if name in scope:
                    # 同一スコープ内での位置（右側が0）
                    # [x, y] において yが見つかれば index=0, xなら index=1
                    local_idx = list(reversed(scope)).index(name)
                    node.is_local = True
                    node.index = accumulated_binders + local_idx
                    found_local = True
                    break
                accumulated_binders += len(scope)
            
            # --- Global 解決 ---
            if not found_local:
                if name not in self.global_registry:
                    self.global_registry[name] = {"id": None, "value": None}
                
                if self.global_registry[name]["id"] is None:
                    self.global_registry[name]["id"] = self.global_count
                    self.global_order.append(name)
                    self.global_count += 1
                
                node.is_local = False
                node.index = self.global_registry[name]["id"]

        for child in node.children:
            self.resolve(child, scope_stack)

        if new_scope is not None:
            scope_stack.pop()

    def format_sexp(self, node, indent=0):
        """Return S-expression lines for a non-Program node as a list of strings."""
        prefix = "  " * indent
        ntype = node.type
        l, c = node.line, node.col

        if ntype == "Variable":
            if node.value == "\"__NULL__\"":
                return [f"{prefix}(Null ({l} {c}))"]
            tag = "L" if node.is_local else "G"
            return [f"{prefix}(Variable ({l} {c}) {node.value} ({tag} {node.index}))"]

        if ntype == "String":
            return [f"{prefix}(String ({l} {c}) {node.value})"]

        if ntype == "SInfo":
            return [f"{prefix}(SInfo ({l} {c}) {node.value})"]

        if ntype == "Null":
            return [f"{prefix}(Null ({l} {c}))"]

        # Non-terminal
        lines = [f"{prefix}({ntype} ({l} {c})"]
        for child in node.children:
            lines.extend(self.format_sexp(child, indent + 1))
        lines[-1] += ")"
        return lines

    def _merge_close_parens(self, text):
        import re
        close_re = re.compile(r'^\s*\)+\s*$')
        result = []
        for line in text.splitlines():
            if close_re.match(line):
                if result:
                    result[-1] = result[-1] + line.strip()
                else:
                    result.append(line.strip())
            else:
                result.append(line)
        return "\n".join(result)

    def print_module(self, roots):
        """Output a single Module S-expression for all Program roots."""
        # Collect filenames from Program nodes in order
        filenames = [root.value for root in roots if root.value]
        f_node = "(F " + " ".join(f'"{n}"' for n in filenames) + ")"

        lines = [f"(Module {f_node}"]

        for name in self.global_order:
            info = self.global_registry[name]
            gid = info["id"]
            val_node = info["value"]
            if val_node is not None:
                # (G id "name"
                #   <Function AST>)
                val_lines = self.format_sexp(val_node, indent=2)
                lines.append(f'  (G {gid} "{name}"')
                lines.extend(val_lines)
                lines[-1] += ")"
            else:
                lines.append(f'  (G {gid} "{name}" Undefined)')

        lines[-1] += ")"
        text = "\n".join(lines)
        print(self._merge_close_parens(text))

def main():
    input_lines = sys.stdin.readlines()
    roots = parse_ast_stream(input_lines)
    
    resolver = Resolver()
    for root in roots:
        resolver.collect_definitions(root)
    
    for root in roots:
        resolver.resolve(root, [])

    resolver.print_module(roots)

if __name__ == "__main__":
    main()
