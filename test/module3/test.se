(include "pure.se")

(define stdout ,(str)
  __OS_print__ str ,()
  stdout)

(define printBoolean ,(Boolean)
  __if_then_else__ Boolean
  (,() ; then
    __OS_print__ "true" ,()
    )
  (,() ; else
    __OS_print__ "false" ,()
    )
  __OS_print__ "\n" ,()
  )

(define case1 ,()
  __NULL__ "A" "B" ,(a b)
  stdout a "\n" b "\n" ,(out)
  )

(define case2 ,()
  __NULL__ __NULL__ ,(a)
  __is_null__ a ,(b)
  __is_null__ b ,(c)
  printBoolean b ,()
  printBoolean c ,()
  )

(define case3 ,()
  __NULL__ "D" ,()
  __NULL__ "B" "C" ,()
  __NULL__ "A" ,()
  ,(a b c d)
  stdout a b c d "\n",(out)
  )

(define test ,()
  case1 ,()
  case2 ,()
  )
