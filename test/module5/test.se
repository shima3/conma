(include "util.se")

(define LList_print1 ,(list)
  __unless__ (,() __LList_is_empty__ list)
  (,()
    __LList_uncons__ __print_exit_error__ list ,(first rest)
    __OS_print__ first ,()
    __OS_print__ "\n" ,()
    LList_print1 rest))

(define case1 ,()
  __LList_cons__ "A" __NULL__ ,(list)
  __LList_cons__ "B" list ,(list)
  __LList_cons__ "C" list ,(list)
  LList_print1 list ,()
  )

(define CChain_print ,(cc)
  __unless__ (,() __LList_is_empty__ cc)
  (,()
    __LList_uncons__ __print_exit_error__ cc ,(first rest)
    __CFrame_get_SInfo__ first ,(si)
    __OS_print__ si ,()
    __OS_print__ "\n" ,()
    CChain_print rest))

(define case2sub ,()
  __CChain_get__ ,(cc)
  CChain_print cc ,()
  )

(define case2 ,()
  case2sub ,()
  __OS_print__ "end\n" ,()
  )

(define LList_print2 ,(list)
  __Cont_get__ ,(return)
  __LList_uncons__ (,(msg)
                     return) list ,(first rest)
  __OS_print__ first ,()
  __OS_print__ "\n" ,()
  LList_print2 rest)

(define case3 ,()
  __LList_cons__ "A" __NULL__ ,(list)
  __LList_cons__ "B" list ,(list)
  __LList_cons__ "C" list ,(list)
  LList_print2 list ,()
  __OS_print__ "end\n" ,()
  )
