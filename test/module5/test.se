(include "pure.se")

(define __LList_is_empty__ ,(list)
  __is_null__ list)

(define print_exit_error ,(msg)
  __OS_print_error__ msg ,()
  __OS_exit_error__)

(define __LList_print__ ,(list)
  __unless__ (,() __LList_is_empty__ list)
  (,()
    __LList_uncons__ print_exit_error list ,(first rest)
    __OS_print__ first ,()
    __OS_print__ "\n" ,()
    __LList_print__ rest))

(define case1 ,()
  __LList_cons__ "A" __NULL__ ,(list)
  __LList_cons__ "B" list ,(list)
  __LList_cons__ "C" list ,(list)
  __LList_print__ list ,()
  )

(define __CChain_print__ ,(cc)
  __unless__ (,() __LList_is_empty__ cc)
  (,()
    __LList_uncons__ print_exit_error cc ,(first rest)
    __CFrame_get_SInfo__ first ,(si)
    __OS_print__ si ,()
    __OS_print__ "\n" ,()
    __CChain_print__ rest))

(define case2sub ,()
  __CChain_get__ ,(cc)
  __CChain_print__ cc)

(define case2 ,()
  case2sub ,()
  __OS_print__ "end\n")

(define __Cont_get__ ,()
  __CChain_get__ ,(cc)
  __LList_uncons__ print_exit_error cc ,(first rest)
  __NULL__ (,()
             __CChain_set__ rest ,()
             __NULL__))

(define __LList_print2__ ,(list)
  __Cont_get__ ,(return)
  __LList_uncons__ (,(msg)
                     return) list ,(first rest)
  __OS_print__ first ,()
  __OS_print__ "\n" ,()
  __LList_print2__ rest)

(define case3 ,()
  __LList_cons__ "A" __NULL__ ,(list)
  __LList_cons__ "B" list ,(list)
  __LList_cons__ "C" list ,(list)
  __LList_print2__ list ,()
  __OS_print__ "end\n" ,()
  )
