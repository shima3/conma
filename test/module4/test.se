(define stdout ,(str)
  __OS_print__ str ,()
  stdout)

(define stderr ,(str)
  __OS_print_error__ str ,()
  stderr)

(define print_error ,(msg)
  stderr "Error: " msg "\n" ,(dummy)
  )

(define print_and_return_error ,(msg)
  stderr "Error: " msg "\n" ,(dummy)
  __NULL__ msg ,()
  )

(define case1 ,()
  __OS_pipe__ ,(in out)
  __OS_write__ print_error out "Hello\n" ,()
  __OS_read__ print_and_return_error in ,(msg)
  stdout "Message: " msg "\n" ,(dummy)
  __OS_close__ print_error out ,()
  __OS_write__ print_error out "World\n" ,()
  __OS_close__ print_error in ,()
  __OS_read__ print_and_return_error in ,(msg)
  )

(define test ,()
  case1 ,()
  case2 ,()
  )
